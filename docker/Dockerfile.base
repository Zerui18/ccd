FROM node:22-bookworm-slim

# System dependencies for Claude Code and general dev work
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    jq \
    openssh-client \
    sudo \
    procps \
    less \
    tmux \
    locales \
    && rm -rf /var/lib/apt/lists/* \
    && sed -i '/en_US.UTF-8/s/^# //' /etc/locale.gen \
    && locale-gen

# Use the existing 'node' user (uid 1000) from the base image — matches official devcontainer
# Create workspace and config directories
RUN mkdir -p /workspace /home/node/.claude && \
    chown -R node:node /workspace /home/node/.claude

# Install Claude Code CLI (always latest on rebuild)
ARG CACHE_BUST
RUN npm install -g @anthropic-ai/claude-code@latest

# Copy entrypoint and tmux config
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
COPY tmux.conf /home/node/.tmux.conf
RUN chown node:node /home/node/.tmux.conf

USER node
WORKDIR /workspace

# Configure git for snapshot tracking
RUN git config --global user.name "ccd" && \
    git config --global user.email "ccd@container" && \
    git config --global init.defaultBranch main

ENV CLAUDE_CONFIG_DIR=/home/node/.claude
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
