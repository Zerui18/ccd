#!/bin/bash
set -euo pipefail

CCD_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=lib/sync.sh
source "$CCD_DIR/lib/sync.sh"
# shellcheck source=lib/session.sh
source "$CCD_DIR/lib/session.sh"
# shellcheck source=lib/stack.sh
source "$CCD_DIR/lib/stack.sh"
# shellcheck source=lib/command.sh
source "$CCD_DIR/lib/command.sh"

usage() {
    cat <<EOF
ccd — Dockerized Claude Code with full filesystem isolation

Usage:
  ccd run <project-path> [options] [-- claude-args...]    (r)
  ccd ls
  ccd diff <session> [path]                               (d)
  ccd sync <session> [--path <glob>]                      (s)
  ccd cp <session> <container-path> [host-path]
  ccd attach <session>                                    (a)
  ccd open <session>                                      (o)
  ccd rm <session>
  ccd clean
  ccd build [--force] [--stack <name>]                    (b)
  ccd auth <status|reset|seed>

Options for 'run':
  --stack <name>      Override auto-detected stack (base, node, python, go, rust)
  --auth <method>     Force auth method: key, oauth (default: auto)
  --name <name>       Custom session name
  --prefix <key>      Tmux prefix key after Ctrl- (default: a)
  --vscode            Auto-open VS Code attached to container
  --print             Print mode (non-interactive, no tmux)
  -p <prompt>         Prompt to pass to Claude Code (non-interactive)

Examples:
  ccd run ./my-app                          # Auto-detect stack, interactive
  ccd run ./my-app -p "fix all tests"       # Non-interactive with prompt
  ccd run ./api --stack python --vscode     # Python stack + VS Code
  ccd diff myapp-a3f2                       # View changes
  ccd sync myapp-a3f2                       # Apply changes to host
  ccd sync myapp-a3f2 --path "src/*"        # Sync only src/ changes
EOF
}

# --- Auth volume management ---

CCD_AUTH_VOLUME="ccd-auth"

# Seed the auth volume from host ~/.claude if it's empty
_ccd_seed_auth_volume() {
    local needs_seed
    needs_seed=$(docker run --rm -v "$CCD_AUTH_VOLUME:/auth" alpine sh -c \
        'test -d /auth && ls /auth/ 2>/dev/null | grep -q . && echo no || echo yes' 2>/dev/null || echo "yes")

    if [ "$needs_seed" = "yes" ]; then
        echo "[ccd] Seeding auth volume from host ~/.claude..."
        docker run --rm \
            -v "$CCD_AUTH_VOLUME:/auth" \
            -v "$HOME/.claude:/host:ro" \
            alpine sh -c 'cp -a /host/. /auth/ && chown -R 1000:1000 /auth'
    fi
}

cmd_auth() {
    local action="${1:-status}"
    case "$action" in
        status)
            if docker volume inspect "$CCD_AUTH_VOLUME" >/dev/null 2>&1; then
                local has_creds
                has_creds=$(docker run --rm -v "$CCD_AUTH_VOLUME:/auth" alpine sh -c \
                    'ls /auth/ 2>/dev/null | head -5')
                if [ -n "$has_creds" ]; then
                    echo "[ccd] Auth volume exists with credentials."
                    echo "$has_creds"
                else
                    echo "[ccd] Auth volume exists but is empty."
                fi
            else
                echo "[ccd] Auth volume does not exist (will be created on first run)."
            fi
            ;;
        reset)
            echo "[ccd] Removing auth volume..."
            docker volume rm "$CCD_AUTH_VOLUME" 2>/dev/null || true
            echo "[ccd] Done. Next run will prompt for login."
            ;;
        seed)
            if [ ! -d "$HOME/.claude" ]; then
                echo "[ccd] ERROR: ~/.claude not found"
                exit 1
            fi
            docker volume rm "$CCD_AUTH_VOLUME" 2>/dev/null || true
            _ccd_seed_auth_volume
            echo "[ccd] Auth volume seeded from host."
            ;;
        *)
            echo "[ccd] ERROR: Unknown auth action: $action"
            echo "Usage: ccd auth <status|reset|seed>"
            exit 1
            ;;
    esac
}

# --- Run command ---

cmd_run() {
    local project_path=""
    local stack=""
    local auth="auto"
    local session_name=""
    local prompt=""
    local claude_args=
    local print_mode=false
    local vscode_mode=false
    local prefix_key=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stack)    stack="$2"; shift 2 ;;
            --auth)     auth="$2"; shift 2 ;;
            --name)     session_name="$2"; shift 2 ;;
            --prefix)   prefix_key="$2"; shift 2 ;;
            --vscode)   vscode_mode=true; shift ;;
            --print)    print_mode=true; shift ;;
            -p)         prompt="$2"; shift 2 ;;
            --)         shift; claude_args=("$@"); break ;;
            -*)         claude_args=("${claude_args[@]+"${claude_args[@]}"}" "$1"); shift ;;
            *)
                if [ -z "$project_path" ]; then
                    project_path="$1"
                else
                    claude_args=("${claude_args[@]+"${claude_args[@]}"}" "$1")
                fi
                shift
                ;;
        esac
    done

    if [ -z "$project_path" ]; then
        echo "[ccd] ERROR: Project path is required"
        usage
        exit 1
    fi

    project_path=$(realpath "$project_path")
    if [ ! -d "$project_path" ]; then
        echo "[ccd] ERROR: $project_path is not a directory"
        exit 1
    fi

    # Auto-detect stack if not specified
    if [ -z "$stack" ]; then
        stack=$(ccd_detect_stack "$project_path")
        echo "[ccd] Detected stack: $stack"
    fi

    # Build the image
    ccd_build_stack "$stack"

    # Determine image to use
    local image
    if [ "$stack" = "base" ] || ! docker image inspect "ccd-${stack}:latest" >/dev/null 2>&1; then
        image="ccd-base:latest"
    else
        image="ccd-${stack}:latest"
    fi

    # Generate session name
    if [ -z "$session_name" ]; then
        session_name=$(ccd_session_name "$project_path")
    fi

    local container_name
    container_name=$(ccd_container_name "$session_name")

    # Build docker run arguments
    local docker_args=(
        --name "$container_name"
        --hostname "ccd-$(basename "$project_path")"
        --label "ccd.managed=true"
        --label "ccd.project=$(basename "$project_path")"
        --label "ccd.project_path=$project_path"
        --label "ccd.stack=$stack"
        --user node
        --cap-drop=ALL
        --security-opt=no-new-privileges
    )

    # Auth setup
    local auth_method=""
    case "$auth" in
        key)
            if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
                echo "[ccd] ERROR: ANTHROPIC_API_KEY not set"
                exit 1
            fi
            docker_args+=(-e ANTHROPIC_API_KEY)
            auth_method="key"
            ;;
        oauth)
            if [ ! -d "$HOME/.claude" ]; then
                echo "[ccd] ERROR: ~/.claude not found for OAuth"
                exit 1
            fi
            auth_method="oauth"
            ;;
        auto)
            if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
                docker_args+=(-e ANTHROPIC_API_KEY)
                auth_method="key"
            elif [ -d "$HOME/.claude" ]; then
                auth_method="oauth"
            else
                echo "[ccd] ERROR: No auth method available. Set ANTHROPIC_API_KEY or log in to Claude."
                exit 1
            fi
            ;;
    esac

    # Auth volume for OAuth — mount at staging path, entrypoint links auth files
    # This keeps projects/sessions/history container-local
    if [ "$auth_method" = "oauth" ]; then
        docker_args+=(-v "$CCD_AUTH_VOLUME:/home/node/.claude-auth")
        _ccd_seed_auth_volume
    fi

    # Tmux mode for interactive sessions
    if [ "$print_mode" = false ]; then
        docker_args+=(-e CCD_TMUX=1)
    fi

    # Custom prefix key
    if [ -n "$prefix_key" ]; then
        docker_args+=(-e "CCD_PREFIX_KEY=$prefix_key")
    fi

    # Add prompt if provided
    local final_claude_args=()
    if [ -n "${claude_args+x}" ]; then
        final_claude_args+=("${claude_args[@]}")
    fi
    if [ -n "$prompt" ]; then
        final_claude_args+=(-p "$prompt")
    fi

    if [ "$print_mode" = true ]; then
        final_claude_args+=(--print)
    fi

    # Determine TTY flags
    local tty_args=()
    if [ "$print_mode" = true ]; then
        tty_args=(-i)  # stdin pipe for print mode
    else
        tty_args=(-t)  # tmux needs a TTY
    fi

    echo "[ccd] Starting session: $session_name"
    echo "[ccd] Project: $project_path"
    echo "[ccd] Stack: $stack | Image: $image"

    # Create container
    docker create \
        "${docker_args[@]}" \
        "${tty_args[@]}" \
        "$image" \
        ${final_claude_args[@]+"${final_claude_args[@]}"} >/dev/null

    # Start container in background
    docker start "$container_name" >/dev/null

    # Copy ~/.claude.json per-container (prefs, not auth tokens)
    if [ "$auth_method" = "oauth" ] && [ -f "$HOME/.claude.json" ]; then
        docker cp "$HOME/.claude.json" "$container_name:/home/node/.claude.json"
        docker exec -u root "$container_name" chown node:node /home/node/.claude.json 2>/dev/null || true
    fi

    # Copy project files in
    ccd_copy_in "$project_path" "$session_name" "$stack"

    # Auto-open VS Code if requested
    if [ "$vscode_mode" = true ]; then
        _ccd_vscode_attach "$container_name"
    fi

    if [ "$print_mode" = true ]; then
        # Non-interactive: just wait for completion
        docker wait "$container_name" >/dev/null
        docker logs "$container_name"
    else
        echo "[ccd] Session started. Press Ctrl-a d to enter command mode."
        echo ""

        # Wait briefly for tmux to initialize
        sleep 1

        # Attach to tmux inside the container
        _ccd_tmux_attach "$container_name"

        # Check if Claude exited or user detached
        if docker exec "$container_name" tmux has-session -t ccd 2>/dev/null; then
            # User detached — enter command mode
            ccd_command_loop "$session_name"
        else
            # Claude exited
            echo ""
            echo "[ccd] Claude session ended."
            echo "[ccd] Review changes:  ccd diff $session_name"
            echo "[ccd] Sync to host:    ccd sync $session_name"
            echo "[ccd] Remove session:  ccd rm $session_name"
        fi
    fi
}

# --- Other commands ---

cmd_ls() {
    ccd_list_sessions
}

cmd_diff() {
    local session="${1:-}"
    local path_filter="${2:-}"

    if [ -z "$session" ]; then
        echo "[ccd] ERROR: Session name required"
        exit 1
    fi

    ccd_diff "$session" "$path_filter"
}

cmd_sync() {
    local session=""
    local path_filter=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --path) path_filter="$2"; shift 2 ;;
            *)
                if [ -z "$session" ]; then
                    session="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$session" ]; then
        echo "[ccd] ERROR: Session name required"
        exit 1
    fi

    local project_path
    project_path=$(ccd_get_project_path "$session")
    if [ -z "$project_path" ]; then
        echo "[ccd] ERROR: Could not determine project path for $session"
        exit 1
    fi

    ccd_sync "$session" "$project_path" "$path_filter"
}

cmd_cp() {
    local session="${1:-}"
    local container_path="${2:-}"
    local host_path="${3:-.}"

    if [ -z "$session" ] || [ -z "$container_path" ]; then
        echo "[ccd] ERROR: Usage: ccd cp <session> <container-path> [host-path]"
        exit 1
    fi

    ccd_cp "$session" "$container_path" "$host_path"
}

cmd_attach() {
    local session="${1:-}"
    if [ -z "$session" ]; then
        echo "[ccd] ERROR: Session name required"
        exit 1
    fi
    ccd_attach_session "$session"
}

cmd_open() {
    local session="${1:-}"
    if [ -z "$session" ]; then
        echo "[ccd] ERROR: Session name required"
        exit 1
    fi
    local container_name
    container_name=$(ccd_container_name "$session")
    _ccd_vscode_attach "$container_name"
}

cmd_rm() {
    local session="${1:-}"
    if [ -z "$session" ]; then
        echo "[ccd] ERROR: Session name required"
        exit 1
    fi
    ccd_remove_session "$session"
}

cmd_clean() {
    ccd_clean_sessions
}

cmd_build() {
    local force=""
    local stack="base"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) force="--force"; shift ;;
            --stack) stack="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    ccd_build_stack "$stack" "$force"
    echo "[ccd] Build complete: $(ccd_image_name "$stack")"
}

# --- Main dispatch (with shorthands) ---

case "${1:-}" in
    r|run)       shift; cmd_run "$@" ;;
    ls)          shift; cmd_ls "$@" ;;
    d|diff)      shift; cmd_diff "$@" ;;
    s|sync)      shift; cmd_sync "$@" ;;
    cp)          shift; cmd_cp "$@" ;;
    a|attach)    shift; cmd_attach "$@" ;;
    o|open)      shift; cmd_open "$@" ;;
    rm)          shift; cmd_rm "$@" ;;
    clean)       shift; cmd_clean "$@" ;;
    b|build)     shift; cmd_build "$@" ;;
    auth)        shift; cmd_auth "$@" ;;
    -h|--help|help|"")
        usage
        ;;
    *)
        echo "[ccd] Unknown command: $1"
        usage
        exit 1
        ;;
esac
